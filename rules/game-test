payload:
  # ======================================================
  # 多人网络底层 (Multiplayer Networking)
  # ======================================================

  # Photon Engine (Exit Games)
  # 全球最广泛使用的多人网络 SDK，Unity/Unreal 游戏首选
  # 连接端点分布于各地区子域名，如 wss.photonengine.io
  - "+.photonengine.io"
  - "+.photonengine.com"
  - "+.exitgames.com"

  # Edgegap
  # 游戏服务器编排平台，提供全球边缘节点中继服务
  # API 及中继端点均在子域名下
  - "+.edgegap.com"
  - "+.edgegap.net"

  # SmartFoxServer
  # Java 多人游戏服务器框架，部分云托管版走官方域名
  - "+.smartfoxserver.com"

  # Colyseus
  # Node.js 多人游戏框架，云托管版 API 在子域名下
  - "+.colyseus.io"
  - "+.colyseus.dev"

  # ======================================================
  # 游戏后端即服务 (Game Backend as a Service)
  # ======================================================

  # Microsoft Azure PlayFab
  # 微软旗下游戏后端平台，提供匹配、排行榜、数据存储等
  # SDK 连接多个区域子域名，如 api.playfab.com
  - "+.playfab.com"
  - "+.playfabapi.com"

  # Heroic Labs（Nakama + Satori）
  # 开源游戏后端 Nakama 的商业托管版及 LiveOps 平台
  - "+.heroiclabs.com"
  - "+.heroic.cloud"

  # AccelByte
  # 跨平台游戏后端，支持主机/PC/移动端账号体系统一
  - "+.accelbyte.io"
  - "+.accelbyte.net"

  # Beamable
  # Unity/Unreal 集成的游戏后端，含商城、社交、内容管理
  - "+.beamable.com"
  - "+.beamable.net"

  # LootLocker
  # 玩家账号与游戏内经济系统后端，跨设备存档支持
  - "+.lootlocker.com"
  - "+.lootlocker.io"

  # brainCloud
  # 独立 BaaS 平台，非大厂旗下，定价对独立游戏友好
  - "+.braincloudservers.com"
  - "+.getbraincloud.com"

  # Pragma Engine
  # 企业级多人游戏后端，专注匹配、组队、社交系统
  - "+.pragma.gg"

  # Amazon GameSparks
  # 已于 2023 年停服，保留以兼容尚在运营的老游戏
  - "+.gamesparks.net"

  # ======================================================
  # 游戏服务器托管与编排 (Game Server Hosting / Orchestration)
  # ======================================================

  # Gameye
  # 游戏专用服务器编排平台，原生集成 Nakama / PlayFab
  - "+.gameye.com"

  # i3D.net
  # 全球专用游戏服务器基础设施，多个大厂游戏使用
  - "+.i3d.net"

  # Unity Multiplay
  # Unity 旗下游戏服务器托管，现整合入 Unity Gaming Services
  - "+.multiplay.co.uk"
  - "+.multiplay.com"

  # ======================================================
  # 游戏引擎配套服务 (Game Engine Services)
  # ======================================================

  # Unity Gaming Services（UGS）
  # 包含 Relay 中继、Matchmaking 匹配、Lobby 大厅等服务
  # 新服务迁移至 unity.com，老游戏仍依赖 unity3d.com
  - "+.unity3d.com"
  - "+.unity.com"

  # Unity Vivox
  # 语音聊天 SDK，被大量多人游戏集成，如 PUBG、Fortnite
  - "+.vivox.com"

  # Epic Online Services（EOS）
  # EOS SDK 运行时端点，提供跨平台账号、成就、匹配服务
  - "+.epicgames.dev"
  - "+.on.epicgames.com"

  # ======================================================
  # 平台 SDK (Platform SDKs)
  # ======================================================

  # Valve Steam
  # Steam 平台运行时、内容分发及 API 端点
  # 注：中国运营域名（steamchina.com 等）不在此列，走直连规则
  - "+.steamgames.com"
  - "+.steampowered.com"
  - "+.steamcontent.com"

  # GOG
  # GOG 平台，无中国专属域名，全球统一走此域名
  - "+.gog.com"

  # ======================================================
  # 游戏数据分析 (Game Analytics)
  # ======================================================

  # GameAnalytics
  # 游戏行为数据上报与分析，SDK 在游戏运行时持续上报
  - "+.gameanalytics.com"

  # ======================================================
  # 防作弊服务 (Anti-Cheat)
  # ======================================================

  # Easy Anti-Cheat（Epic 旗下）
  # 广泛集成于 AAA 游戏，启动时验证连接官方端点
  - "+.easyanticheat.net"

  # BattlEye
  # 集成于 Arma 系列、PUBG、彩虹六号等，行为同上
  - "+.battleye.com"

  # ======================================================
  # 对战 / 回滚网络 (Matchmaking / Rollback Networking)
  # ======================================================

  # GGPO
  # 格斗游戏回滚网络协议，多款街机对战游戏使用
  - "+.ggpo.net"

  # EOS 登录凭证验证走此域名，缺少会导致登录失败
  - "+.epicgames.com"

  # Unity Relay / Lobby 新服务端点，unity3d.com 不覆盖
  - "+.services.unity.com"

  # Vivox 语音，PUBG / Fortnite 等大量游戏集成
  - "+.vivox.com"
